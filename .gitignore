# AdTree binary directories (kept outside this repo by convention)
Tools/
AdTree-v*/

# AdTree reconstruction outputs — regenerated by running AdTree on the
# committed .xyz inputs (see README "Reproducing the results" section).
# These files are large (10-160 MB) and exceed GitHub's per-file limit.
data/real/adtree_output/*.obj
data/real/adtree_output/*.mtl
data/synthetic/adtree_output/*.obj
data/synthetic/adtree_output/*.mtl

# Leftover / superseded mesh versions
**/*_old.obj
**/*_old.mtl
**/*_old_*.obj
**/*_old_*.mtl
